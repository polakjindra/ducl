# Absolute path to the local git repo you want conductor to work in
REPO_PATH=/absolute/path/to/your/repo

# Absolute path where conductor will create git worktrees (must be writable; created if absent)
WORKTREE_BASE_PATH=/absolute/path/to/worktrees

# Branch that new workspaces are cut from (must exist in the repo)
BASE_BRANCH=main

# How many Claude Code sessions may run concurrently (queue the rest)
MAX_CONCURRENT_AGENTS=3

# Port the local web console listens on (binds to 127.0.0.1 only)
PORT=4000

# Optional: absolute path to claude CLI binary
# conductor searches PATH automatically; set this if auto-detection fails
# Fallbacks checked: ~/.local/bin/claude, /usr/local/bin/claude, /opt/homebrew/bin/claude (Mac/Linux)
#                    %USERPROFILE%\.local\bin\claude (Windows)
CLAUDE_BIN=
